---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CallToAction from '../../components/CallToAction.astro';
import fleetImage from '../../assets/images/fleet/multiple-cars.jpg';
---

<BaseLayout
  title="Gallery | Aviemore Taxis"
  description="Photo gallery of the Aviemore Taxis fleet — 4 and 8 seater vehicles serving Aviemore and the Scottish Highlands."
>
  <PageHeader title="Gallery" intro="Take a look at our fleet." />

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        <article class="card">
          <a href="/gallery/cars">
            <Image
              src={fleetImage}
              alt="The Aviemore Taxis fleet"
              width={700}
              format="webp"
              loading="eager"
            />
          </a>
          <div class="card__body">
            <h3><a href="/gallery/cars">Vehicles</a></h3>
            <p>Our 4 and 8 seater taxis and private hire vehicles.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <CallToAction />
</BaseLayout>

<style>
  .card h3 a {
    text-decoration: none;
  }
</style>
