---
import {
  EMAIL,
  FACEBOOK,
  NAV,
  PHONE,
  PHONE_HREF,
  SITE_NAME,
  TWITTER,
} from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <h2>About Us</h2>
      <p>
        Aviemore’s largest independent and family owned taxi company, trusted
        since 1987. Whatever you require, we are positive we can offer you an
        outstanding service — call us on
        <a href={PHONE_HREF}>{PHONE}</a>.
      </p>
    </div>
    <div>
      <h2>Useful Links</h2>
      <ul>
        {
          NAV.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <h2>Get In Touch</h2>
      <ul>
        <li><a href={PHONE_HREF}>{PHONE}</a></li>
        <li><a href={`mailto:${EMAIL}`}>{EMAIL}</a></li>
        <li><a href={FACEBOOK} rel="noopener">Facebook</a></li>
        <li><a href={TWITTER} rel="noopener">Twitter</a></li>
      </ul>
    </div>
  </div>
  <div class="site-footer__legal">
    <div class="container">
      © {year} {SITE_NAME}. All rights reserved. Established 1987.
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy-900);
    color: rgba(255, 255, 255, 0.82);
    margin-top: auto;
  }

  .site-footer h2 {
    color: var(--white);
    font-size: 1.1rem;
    margin-bottom: 0.8em;
  }

  .site-footer a {
    color: var(--amber-500);
    text-decoration: none;
  }

  .site-footer a:hover {
    text-decoration: underline;
  }

  .site-footer__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    padding-top: 3rem;
    padding-bottom: 2.5rem;
  }

  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer li {
    padding: 0.2rem 0;
  }

  .site-footer__legal {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding: 1.1rem 0;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
  }
</style>
