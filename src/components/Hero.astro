---
import { Picture } from 'astro:assets';
import banner from '../assets/images/branding/banner.jpg';
import { PHONE, PHONE_HREF } from '../data/site';

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero">
  <Picture
    src={banner}
    formats={['avif', 'webp']}
    widths={[480, 940]}
    sizes="100vw"
    alt=""
    loading="eager"
    fetchpriority="high"
    class="hero__image"
  />
  <div class="hero__overlay"></div>
  <div class="container hero__content">
    <h1>{title}</h1>
    <p>{subtitle}</p>
    <div class="hero__actions">
      <a href={PHONE_HREF} class="btn btn--primary">Call {PHONE}</a>
      <a href="/services" class="btn btn--ghost">Our Services</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero :global(picture) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero :global(.hero__image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(10, 25, 42, 0.85) 0%,
      rgba(10, 25, 42, 0.65) 50%,
      rgba(10, 25, 42, 0.40) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    color: var(--white);
    padding-top: 5rem;
    padding-bottom: 5rem;
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero__content h1 {
    color: var(--white);
    max-width: 22ch;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }

  .hero__content p {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.95);
    max-width: 44ch;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
</style>
