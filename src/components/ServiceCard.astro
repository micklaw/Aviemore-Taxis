---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  href: string;
  image: ImageMetadata;
  alt: string;
}

const { title, href, image, alt } = Astro.props;
---

<article class="card">
  <a href={href}>
    <Image src={image} alt={alt} width={700} format="webp" loading="lazy" />
  </a>
  <div class="card__body">
    <h3><a href={href}>{title}</a></h3>
    <p><slot /></p>
    <a class="card__more" href={href}>Read more →</a>
  </div>
</article>

<style>
  .card h3 a {
    text-decoration: none;
  }

  .card__more {
    font-weight: 700;
    text-decoration: none;
    color: var(--amber-600);
  }
</style>
