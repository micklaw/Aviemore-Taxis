---
import { Image } from 'astro:assets';
import logo from '../assets/images/branding/logo.png';
import MobileNav from './MobileNav.tsx';
import { NAV, PHONE, PHONE_HREF, SITE_NAME } from '../data/site';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${SITE_NAME} home`}>
      <Image src={logo} alt={SITE_NAME} width={200} height={55} loading="eager" />
    </a>
    <nav class="site-header__nav" aria-label="Main">
      <ul>
        {
          NAV.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a href={PHONE_HREF} class="btn btn--primary site-header__phone">
      {PHONE}
    </a>
    <MobileNav client:idle links={NAV} phone={PHONE} phoneHref={PHONE_HREF} />
  </div>
</header>

<style is:global>
  .site-header {
    background: var(--white);
    border-bottom: 1px solid var(--slate-100);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .site-header__brand {
    margin-right: auto;
  }

  .site-header__nav ul {
    display: flex;
    gap: 1.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    text-decoration: none;
    font-weight: 600;
    color: var(--navy-800);
    padding-bottom: 0.2rem;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    border-bottom: 3px solid var(--amber-500);
  }

  .mobile-nav {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (max-width: 820px) {
    .site-header__nav,
    .site-header__phone {
      display: none;
    }

    .mobile-nav {
      display: block;
    }

    .mobile-nav__toggle {
      background: none;
      border: 0;
      font-size: 1.7rem;
      color: var(--navy-800);
      cursor: pointer;
      padding: 0.25rem 0.5rem;
    }

    .mobile-nav__menu {
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: var(--white);
      border-bottom: 1px solid var(--slate-100);
      box-shadow: var(--shadow);
    }

    .mobile-nav__menu ul {
      list-style: none;
      margin: 0;
      padding: 0.5rem 1.25rem 1rem;
    }

    .mobile-nav__menu a {
      display: block;
      padding: 0.7rem 0;
      font-weight: 600;
      text-decoration: none;
      color: var(--navy-800);
    }

    .mobile-nav__phone {
      color: var(--amber-600) !important;
    }
  }
</style>
