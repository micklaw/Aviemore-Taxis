{
  "trailingSlash": "auto",
  "routes": [
    { "route": "/index.html", "redirect": "/", "statusCode": 301 },
    { "route": "/services.html", "redirect": "/services", "statusCode": 301 },
    { "route": "/about.html", "redirect": "/about", "statusCode": 301 },
    { "route": "/gallery.html", "redirect": "/gallery", "statusCode": 301 },
    { "route": "/contact.html", "redirect": "/contact", "statusCode": 301 },
    { "route": "/news.html", "redirect": "/", "statusCode": 301 },
    { "route": "/news/*", "redirect": "/", "statusCode": 301 }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/404.html", "statusCode": 404 }
  }
}
